# --- Databricks workspace (e2-demo-field-eng) ---
DATABRICKS_HOST="https://e2-demo-field-eng.cloud.databricks.com"
DATABRICKS_TOKEN="dapi-REPLACE-WITH-YOUR-PAT"

# --- Anthropic ---
ANTHROPIC_API_KEY="sk-ant-REPLACE-WITH-YOUR-KEY"

# --- MLflow tracking backend ---
MLFLOW_TRACKING_URI="databricks"
MLFLOW_EXPERIMENT_NAME="/Users/austin.choi@databricks.com/claude-code-demo"
# Optional — useful for notebooks that filter by experiment id
MLFLOW_EXPERIMENT_ID=""

# --- Claude Code CLI tracing switch ---
MLFLOW_CLAUDE_TRACING_ENABLED="true"

# --- Judge / issue-detection LLM endpoint ---
# Default: Databricks-hosted Claude Sonnet via Model Serving.
# Swap to databricks-llama-4-maverick if preferred.
JUDGE_ENDPOINT="databricks-claude-sonnet-4"
